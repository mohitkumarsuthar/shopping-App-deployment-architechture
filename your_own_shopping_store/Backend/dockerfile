# devops-1/your_own_shopping_store/Backend/Dockerfile

FROM node:20-alpine AS build

WORKDIR /app

COPY package*.json ./
RUN npm install

COPY . .
ENV PORT=5000
ENV DB_HOST=postgres-db
ENV DB_PORT=5432
ENV RAZORPAY_KEY_ID=your_razorpay_key_id
ENV RAZORPAY_KEY_SECRET=your_razorpay_secret

ENV <h2 id="usage">Usage</h2>
ENV CLOUDINARY_CLOUD_NAME=dummy
ENV CLOUDINARY_API_KEY=dummy
ENV CLOUDINARY_API_SECRET=dummy
ENV VITE_API_BASE_URL=http://localhost:5000
ENV VITE_BACKEND_URL=http://localhost:5000

ENV DATABASE_URL=shopping-db.crcey428275y.ap-south-1.rds.amazonaws.com
ENV JWT_SECRET=mysecretkey123
ENV DB_NAME=shopdb
ENV EXPOSE 5000
ENV DB_USER=postgres
ENV DB_PASSWORD=Shopping#123

CMD ["npm", "start"]
